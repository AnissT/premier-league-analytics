{
  "name": "Premier League 2024/25",
  "dataColors": [
    "#00FF85",
    "#7B2D8B",
    "#E8003D",
    "#FFFFFF",
    "#FFD700",
    "#00BFFF",
    "#FF6B35",
    "#A8D8EA"
  ],
  "background": "#37003C",
  "foreground": "#FFFFFF",
  "tableAccent": "#00FF85",
  "visualStyles": {
    "*": {
      "*": {
        "background": [
          {
            "color": { "solid": { "color": "#2D0033" } },
            "transparency": 0
          }
        ],
        "border": [
          {
            "color": { "solid": { "color": "#5A0066" } }
          }
        ],
        "fontColor": [
          {
            "color": { "solid": { "color": "#FFFFFF" } }
          }
        ],
        "title": [
          {
            "fontColor": { "solid": { "color": "#00FF85" } },
            "background": { "solid": { "color": "#37003C" } },
            "fontSize": 12,
            "fontFamily": "Segoe UI"
          }
        ]
      }
    },
    "card": {
      "*": {
        "background": [
          {
            "color": { "solid": { "color": "#2D0033" } }
          }
        ],
        "dataLabels": [
          {
            "color": { "solid": { "color": "#00FF85" } },
            "fontSize": 28,
            "fontFamily": "Segoe UI"
          }
        ],
        "categoryLabels": [
          {
            "color": { "solid": { "color": "#C084D4" } },
            "fontSize": 11
          }
        ],
        "border": [
          {
            "color": { "solid": { "color": "#5A0066" } },
            "show": true
          }
        ]
      }
    },
    "barChart": {
      "*": {
        "dataPoint": [
          {
            "defaultColor": { "solid": { "color": "#00FF85" } }
          }
        ],
        "categoryAxis": [
          {
            "labelColor": { "solid": { "color": "#C084D4" } },
            "fontSize": 10
          }
        ],
        "valueAxis": [
          {
            "labelColor": { "solid": { "color": "#C084D4" } },
            "gridlineColor": { "solid": { "color": "#5A0066" } }
          }
        ],
        "background": [
          {
            "color": { "solid": { "color": "#2D0033" } }
          }
        ]
      }
    },
    "scatterChart": {
      "*": {
        "background": [
          {
            "color": { "solid": { "color": "#2D0033" } }
          }
        ],
        "categoryAxis": [
          {
            "labelColor": { "solid": { "color": "#C084D4" } },
            "gridlineColor": { "solid": { "color": "#5A0066" } }
          }
        ],
        "valueAxis": [
          {
            "labelColor": { "solid": { "color": "#C084D4" } },
            "gridlineColor": { "solid": { "color": "#5A0066" } }
          }
        ]
      }
    },
    "slicer": {
      "*": {
        "background": [
          {
            "color": { "solid": { "color": "#2D0033" } }
          }
        ],
        "data": [
          {
            "fontColor": { "solid": { "color": "#FFFFFF" } },
            "fontSize": 11
          }
        ],
        "selection": [
          {
            "selectAllCheckboxEnabled": true,
            "singleSelect": false
          }
        ]
      }
    },
    "tableEx": {
      "*": {
        "background": [
          {
            "color": { "solid": { "color": "#2D0033" } }
          }
        ],
        "values": [
          {
            "fontColorPrimary": { "solid": { "color": "#FFFFFF" } },
            "backColorPrimary": { "solid": { "color": "#2D0033" } },
            "fontColorSecondary": { "solid": { "color": "#E0E0E0" } },
            "backColorSecondary": { "solid": { "color": "#37003C" } }
          }
        ],
        "columnHeaders": [
          {
            "fontColor": { "solid": { "color": "#00FF85" } },
            "backColor": { "solid": { "color": "#4A0055" } },
            "fontSize": 11,
            "fontFamily": "Segoe UI"
          }
        ],
        "grid": [
          {
            "gridVertical": true,
            "gridVerticalColor": { "solid": { "color": "#5A0066" } },
            "gridHorizontalColor": { "solid": { "color": "#5A0066" } }
          }
        ]
      }
    },
    "page": {
      "*": {
        "background": [
          {
            "color": { "solid": { "color": "#37003C" } },
            "transparency": 0
          }
        ],
        "outspace": [
          {
            "color": { "solid": { "color": "#2D0033" } }
          }
        ]
      }
    }
  },
  "textClasses": {
    "callout": {
      "fontSize": 45,
      "fontFace": "Segoe UI",
      "color": "#00FF85"
    },
    "title": {
      "fontSize": 16,
      "fontFace": "Segoe UI",
      "color": "#FFFFFF"
    },
    "header": {
      "fontSize": 12,
      "fontFace": "Segoe UI",
      "color": "#C084D4"
    },
    "label": {
      "fontSize": 10,
      "fontFace": "Segoe UI",
      "color": "#C084D4"
    }
  }
}
